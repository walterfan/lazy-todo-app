{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and note windows",
  "windows": ["main", "note-*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:tray:default",
    "core:menu:default",
    "core:event:default",
    "notification:default"
  ]
}
