{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri-docs/dev/.vitepress/custom-schema/config.schema.json",
  "productName": "Lazy Todo App",
  "version": "0.1.0",
  "identifier": "com.fanyamin.lazytodoapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lazy Todo App",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
