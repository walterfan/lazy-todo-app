#: ../../07-conventions.md:9 f265947f95294fe1aaa7895609513e85
msgid "**Edition**: 2021"
msgstr ""

#: ../../07-conventions.md:10 824a2f7b1cdd4d65941ab0c7464ea88a
msgid "**Formatting**: Standard `rustfmt` defaults"
msgstr ""

#: ../../07-conventions.md:11 ef21788b860b4d869c1303357749eab9
msgid ""
"**Naming**: `snake_case` for files, functions, variables; `PascalCase` "
"for structs"
msgstr ""

#: ../../07-conventions.md:12 f63550b459bf48f0a0b5910632b713b1
msgid ""
"**Error handling**: All Tauri commands return `Result<T, String>`, "
"mapping internal errors via `.map_err(|e| e.to_string())`"
msgstr ""

#: ../../07-conventions.md:13 d52e2dce9a7048dca3442fbc6c397006
msgid ""
"**Database access**: All SQL goes through `db.rs` methods; command "
"handlers never construct SQL directly"
msgstr ""

#: ../../07-conventions.md:14 5b68bdb42b93458ab0a25d077a6f5298
msgid ""
"**State sharing**: `Database` struct wraps `Mutex<Connection>` and is "
"injected via `app.manage()`; accessed in commands via `State<'_, "
"Database>`"
msgstr ""

#: ../../07-conventions.md:15 23587c4fa1324b9eaaf42967dea68b4b
msgid ""
"**Serde**: All models derive `Serialize`/`Deserialize` for JSON IPC; "
"input structs use `Option<T>` for partial updates"
msgstr ""

#: ../../07-conventions.md:17 0c0998afa3cd43f0815e7cefe31d9efe
msgid "TypeScript / React"
msgstr ""

#: ../../07-conventions.md:19 19e87c134a5c4952a1f1dbf991170692
msgid "**React version**: 18 with function components only (no class components)"
msgstr ""

#: ../../07-conventions.md:20 2e4f7e282c0e4aa4bd0ab54c4a714b82
msgid "**State**: `useState` and `useEffect` hooks; no external state library"
msgstr ""

#: ../../07-conventions.md:21 eabd8ec5b1864656b3667f524c9038e2
msgid ""
"**Hooks**: Custom hooks prefixed with `use` encapsulate Tauri `invoke()` "
"calls and local state"
msgstr ""

#: ../../07-conventions.md:22 4279f34e1a0249c6863b75b935210557
msgid "**Components**: One component per file, `PascalCase` filenames"
msgstr ""

#: ../../07-conventions.md:23 448fbae19b2a4390bb4911b51e3af887
msgid ""
"**Types**: Separate `types/*.ts` files for domain types; interfaces "
"preferred over type aliases for objects"
msgstr ""

#: ../../07-conventions.md:24 e87d14307f174a0fb54713709c7a63a2
msgid ""
"**Imports**: Named imports from `@tauri-apps/api/core` (`invoke`) and "
"`@tauri-apps/api/event` (`listen`)"
msgstr ""

#: ../../07-conventions.md:25 7587ac3b9d0347ab9131e1072ae3362c
msgid "**Strict mode**: TypeScript strict mode enabled via `tsconfig.json`"
msgstr ""

#: ../../07-conventions.md:27 e1b4a9775c4a446ba796e8fd5a43d8be
msgid "CSS"
msgstr ""

#: ../../07-conventions.md:29 a817c5c0567a4371ba2ebfb1e696ea56
msgid "**Single file**: All styles in `src/App.css`"
msgstr ""

#: ../../07-conventions.md:30 e2dfb82491bd4500a730d8a94d1479c1
msgid ""
"**Theme**: Dark theme using CSS custom properties (`--bg-primary`, "
"`--text-main`, etc.)"
msgstr ""

#: ../../07-conventions.md:31 633385734b7f4032bec6efb738fb92c3
msgid ""
"**Naming**: BEM-like flat classes (`.pomo-ring`, `.note-card`, `.tab-"
"btn.active`)"
msgstr ""

#: ../../07-conventions.md:32 5a6d61274acf42788694fd964cfcaa45
msgid "**Layout**: Flexbox and CSS Grid; no CSS framework"
msgstr ""

#: ../../07-conventions.md:33 73d89ca2cc80472e92a0b37d4c299b44
msgid "**Animations**: CSS `@keyframes` for alerts and transitions"
msgstr ""

