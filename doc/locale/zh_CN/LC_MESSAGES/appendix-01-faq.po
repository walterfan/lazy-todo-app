#: ../../appendix-01-faq.md:101 6a24f36ad02946e5bfb87e3317572438
msgid "Data & Storage"
msgstr ""

#: ../../appendix-01-faq.md:103 219f41afacdd441db23df92a27d186b3
msgid "Q: Where is my data stored?"
msgstr ""

#: ../../appendix-01-faq.md:105 d60754fde49845b8be41786309f99bc7
msgid ""
"The app uses SQLite. The database file is stored in the platform-specific"
" app data directory:"
msgstr ""

#: ../../appendix-01-faq.md 567d02fcc6874b078c65ddc228bd29e8
msgid "Path"
msgstr ""

#: ../../appendix-01-faq.md 53b1d3d36a934c5283f5d67077c348a9
msgid "`~/Library/Application Support/com.lazy-todo-app/`"
msgstr ""

#: ../../appendix-01-faq.md 2e58d0a47fee4eb38ff50e129f55eb40
msgid "`%APPDATA%\\com.lazy-todo-app\\`"
msgstr ""

#: ../../appendix-01-faq.md f27161825df44ca7b0231bb2c0f68ecf
msgid "`~/.local/share/com.lazy-todo-app/`"
msgstr ""

#: ../../appendix-01-faq.md:113 c67e44485ec245fc9dc08071d483a591
msgid "Q: Can I back up my data?"
msgstr ""

#: ../../appendix-01-faq.md:115 d387e891230a4bbc93f5556f37d7cfce
msgid ""
"Yes. Simply copy the SQLite database file from the path above. You can "
"also export tasks via the app's export feature (if available)."
msgstr ""

#: ../../appendix-01-faq.md:117 4a0c82097fca4879888b1f55cd991456
msgid "Q: Is my data synced to the cloud?"
msgstr ""

#: ../../appendix-01-faq.md:119 0c8f123e55634012a21e788a71a43ee3
msgid ""
"No. All data is stored locally. This is by design for privacy and "
"offline-first usage."
msgstr ""

#: ../../appendix-01-faq.md:123 2661d362835d496c9a0a32643360cf8e
msgid "Build & Release"
msgstr ""

#: ../../appendix-01-faq.md:125 d8ca699f898848a88c0e9b9907baea5a
